    .plastic-code{
      width: 42px;
      height: 42px;
      border: 1px solid rgba(197,160,89,0.4);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      margin-right: 14px;
      color: #ffc107;
      font-weight: 500;
      flex-shrink: 0;
    }

    .info-card .step-item{
      margin-bottom: 20px;
    }

    .info-card .step-number{
