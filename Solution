  <style>
    *{
      font-family: 'Inria Serif', serif;
    }

    body{
      font-family: 'Inria Serif', serif;
      background: #ffffff;
      color: #4a4038;
    }

    /* navbar */
    .navbar{
      background: transparent;
      position: relative;
      z-index: 100;
    }
    .navbar-nav .nav-link{
      color: #ffffff;
      transition: 0.3s;
      position: relative;
    }

    .navbar-nav .nav-link:hover{
      color: #dea700;
    }

    .navbar-nav .nav-link.active{
      color: #ffc107 !important;
    }

     .dropdown-item{
        transition: 0.3s;
        color: #ffc107;
    }
    .dropdown-item:hover{
        background-color: #ffc107;
        color: white;
    }

    .section-tag{
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(197,160,89,0.15);
      color: #ffc107;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
    }

    .solution-label{
      font-size: 12px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #ffc107;
      margin: 0;
    }

    .main-title{
      font-family: 'Inria Serif', serif;
      font-size: 56px;
      margin-bottom: 25px;
      line-height: 1.1;
      color: #3f352d;
    }

    .main-title em,
    .main-title span{
      color: #ffc107;
      font-style: italic;
    }

    .description{
      font-size: 15px;
      line-height: 1.9;
      color: #6b6b6b;
      margin-bottom: 24px;
      font-weight: 300;
    }

    .sub-title{
      font-family: 'Inria Serif', serif;
      font-size: 28px;
      margin-bottom: 20px;
      color: #3f352d;
    }

    .step-item{
      display: flex;
      align-items: flex-start;
      gap: 18px;
      margin-bottom: 22px;
    }

    .step-number{
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1px solid rgba(197,160,89,0.4);
      color: #ffc107;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
      transition: 0.3s ease;
    }

    .step-item:hover .step-number{
      background: #ffc107;
      color: white;
    }

    .step-text{
      font-size: 14px;
      line-height: 1.8;
      color: #666;
      padding-top: 8px;
      font-weight: 300;
    }

    /* Waste Type Cards */
    .waste-box{
      display: flex;
      gap: 14px;
      padding: 14px;
      border-radius: 14px;
      margin-bottom: 14px;
      align-items: flex-start;
    }

    .waste-box i{
      font-size: 20px;
      margin-top: 3px;
    }

    .waste-box h6{
      margin: 0;
      font-size: 15px;
      font-weight: 500;
    }

    .waste-box p{
      margin: 4px 0 0;
      font-size: 12px;
      color: #6d6d6d;
    }

    /* Bin Cards */
    .bin-card{
      background: white;
      border: 1px solid #eeeeee;
      border-radius: 18px;
      padding: 28px 18px;
      text-align: center;
      height: 100%;
      transition: 0.3s ease;
      box-shadow: 0 3px 10px rgba(0,0,0,0.03);
    }

    .bin-card:hover{
      transform: translateY(-5px);
    }

    .icon-circle{
      width: 58px;
      height: 58px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      color: white;
      font-size: 24px;
    }

    .bin-card h5{
      font-size: 16px;
      margin-bottom: 8px;
      font-weight: 500;
    }

    .bin-card p{
      font-size: 12px;
      color: #6d6d6d;
      line-height: 1.7;
      margin: 0;
    }

    /* solution 2 */
    .solution_small_boxes{
      background-color: #f8f5f1;
      padding: 8px 14px;
      border-radius: 5px;
      display: flex;
      align-items: center;
      margin-left: 5px;
      margin-right: 5px;
      width: fit-content;
      box-shadow: 1px 2px 9px rgba(0,0,0,0.1);
      font-size: 14px;
    }

    .card-box{
      background-color: #f8f5f1;
      border-radius: 10px;
      width: 200px;
    }

    .card-box .icon-circle{
      background-color: rgb(163,203,83);
      width: 60px;
      height: 60px;
      border-radius: 100%;
    }

    .arrow_icon{
      font-size: 35px;
      color: rgb(165,165,165);
    }

    .checked_sentences{
      margin-bottom: 12px;
      display: flex;
      align-items: center;
    }

    @media screen and (max-width:768px){
      .solution_img_container{
        display: none !important;
      }
    }

    /* solution 3 */
    .small-title{
      display: flex;
      align-items: center;
      gap: 10px;
      color: #ffc107;
      font-size: 14px;
      margin-bottom: 20px;
    }

    .circle{
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(197,160,89,0.15);
      color: #ffc107;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
    }

    .section-title{
      margin-top: 30px;
      margin-bottom: 20px;
      font-size: 24px;
      font-weight: bold;
      color: #3f352d;
    }

    .tag{
      background: white;
      padding: 10px 18px;
      border-radius: 10px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.08);
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin: 8px;
      font-size: 15px;
    }

    .main-img{
      width: 100%;
      border-radius: 6px;
      object-fit: cover;
    }

    .mini-box{
      position: absolute;
      top: 15px;
      right: 15px;
      background: white;
      padding: 10px;
      width: 160px;
      border-radius: 5px;
      font-size: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .mini-box h6{
      color: #7a8c5d;
      font-weight: bold;
      margin-bottom: 5px;
    }

    .steps{
      margin-top: 40px;
    }

    /* solution 4 */
    .plastic-section{
      background: #ffffff;
    }

    .plastic-section .main-title{
      text-align: center;
      margin-bottom: 20px;
    }

    .plastic-section .description{
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 40px;
    }

    .info-card:hover{
      transform: translateY(-5px);
    }

    .info-card .card-title{
      font-size: 22px;
      margin-bottom: 25px;
      font-weight: 500;
      color: #3f352d;
    }

    .plastic-item{
      margin-bottom: 18px;
    }

    .info-card {
            background: #f7f5f0;
            border: 1px solid #c2baa8;
            border-radius: 12px;
            padding: 40px 30px;
            height: 100%;
            color: #2b2826;
        }
 
        .icon-circle {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background: #9ca670;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 30px;
            font-size: 22px;
            color: #f7f5f0;
        }
 
        .card-title {
            font-size: 32px;
            margin-bottom: 35px;
            font-weight: 500;
            color: #4b4338;
        }
 
        .number-badge {
            width: 32px;
            height: 32px;
            border: 1px solid #4b4338;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
            flex-shrink: 0;
        }
 
        .badge-box {
            border: 1px solid #9c9482;
            border-radius: 4px;
            padding: 2px 6px;
            font-size: 11px;
            font-weight: bold;
            display: inline-block;
            width: 45px;
            text-align: center;
            color: #6a6258;
        }
 
        .alternative-row {
            min-height: 45px;
        }
 
        @media (max-width: 768px) {
            .main-title { font-size: 42px; }
