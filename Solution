    .technology-section{
      padding: 100px 0;
      min-height: 100vh;
      overflow: hidden;
      background: linear-gradient(rgba(37,37,37,0.72),rgba(37,37,37,0.72)), url('pbl_image/solution_hero_city.png');
      background-size: cover;
      background-position: center;
    }

    .technology-section .main-title{
      color: #ffffff;
    }

    .main-description{
      color: #eeeeee;
      max-width: 450px;
      margin: auto;
      line-height: 1.8;
      font-size: 15px;
    }

    .solution-card{
      background: #f5f2ec;
      border-radius: 24px;
      height: 75vh;
      max-height: 760px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-shadow: 0 15px 40px rgba(0,0,0,0.25);
      scrollbar-width: none;
    }

    .card-content{
      flex: 1;
      overflow-y: auto;
      padding: 35px;
      scrollbar-width: none;
    }

    .card-content::-webkit-scrollbar{
      display: none;
