    .explore-btn{
      width: 100%;
      background: #ffc107;
      color: white;
      border: none;
      border-radius: 50px;
      padding: 14px 30px;
      text-decoration: none;
      display: block;
      text-align: center;
      transition: 0.3s;
    }

    .explore-btn:hover{
      background: #ffc107;
      color: white;
    }

    .slider-btn{
      width: 55px;
      height: 55px;
      border: none;
      border-radius: 50%;
      background: #d6c98f;
      color: #2d2d2d;
      font-size: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }

    .slider-prev{
      left: 5%;
    }

    .slider-next{
      right: 5%;
    }

    .carousel-indicators{
      position: relative;
      margin-top: 30px;
    }

    .carousel-indicators [data-bs-target]{
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #ffc107;
      border: none;
      margin: 0 6px;
      opacity: 0.5;
    }

    .carousel-indicators .active{
      opacity: 1;
    }

    .carousel-item{
      transition: transform 0.7s ease-in-out;
    }

    @media(max-width:991px){
