      font-size: 18px;
      flex-shrink: 0;
    }

    .eco-text{
      font-size: 14px;
      color: #555;
    }

    /* solution 5 */
    .cleanup-section{
      position: relative;
      min-height: 100vh;
      background: linear-gradient(rgba(0,0,0,0.75),rgba(0,0,0,0.75)), url('pbl_image/solution_hero_citybushes.png') center/cover no-repeat;
      padding: 100px 0;
      margin-left: 0;
    }

    .cleanup-section .main-title{
      color: #ffffff;
    }

    .cleanup-section .sub-title{
      color: #ffffff;
    }

    .cleanup-section .description{
      color: #ecebeb;
    }

    .cleanup-section .step-number{
      border-color: #ffc107;
      color: #ffc107;
    }

    .cleanup-section .step-item:hover .step-number{
      background: #ffc107;
      color: white;
    }

    .cleanup-section .step-text{
      color: #e5e5e5;
    }

    .join-title{
      font-size: 2rem;
      font-weight: 700;
      color: #ffffff;
    }

    .join-sub{
      color: #ddd;
      margin-bottom: 30px;
    }

    .join-card{
      border: 2px solid rgba(255,255,255,0.7);
      border-radius: 16px;
      padding: 30px 20px;
      text-align: center;
      height: 100%;
      transition: 0.3s ease;
      backdrop-filter: blur(3px);
      background: rgba(255,255,255,0.03);
    }

    .join-card:hover{
      transform: translateY(-5px);
      border-color: #ffc107;
    }

    .join-card i{
      font-size: 2rem;
      color: #fff;
      margin-bottom: 15px;
    }

    .join-card h6{
      margin: 0;
      color: #ffc107;
      font-weight: 500;
    }

    .fact-box{
      margin-top: 35px;
      border: 2px solid #ffc107;
      border-radius: 14px;
      padding: 25px;
      background: rgba(255,255,255,0.03);
    }

    .fact-box h5{
      color: #fff;
      margin-bottom: 10px;
      font-weight: 600;
    }

    .fact-box p{
      color: #ddd;
      margin: 0;
      line-height: 1.7;
    }

    /* solution 6 */
    .reusable-image:hover{
      transform: scale(1.02);
    }

    .reusable-image{
      transition: 0.5s ease;
    }

    .benefit-box{
      background: #fff;
      border-radius: 14px;
      padding: 14px 16px;
      gap: 10px;
      transition: 0.3s ease;
      height: 100%;
      box-shadow: 0 12px 28px rgba(0,0,0,0.12);
      display: flex;
      align-items: center;
    }

    .benefit-box:hover{
      transform: translateY(-2px);
    }

    .benefit-box span{
      font-size: 13px;
      color: #666;
      font-weight: 300;
    }

   /* solution 7 */
    .solution_side_session{
      border: 1px solid #eeeeee !important;
      border-radius: 20px;
      background-color: #f8f5f1 !important;
      padding: 30px;
    }

    .gov-card{
      border: 1px solid #eeeeee;
      border-radius: 20px;
      background-color: #f8f5f1;
      transition: 0.3s ease;
    }

    .gov-card:hover{
      transform: translateY(-3px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .gov-step-num{
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1px solid rgba(197,160,89,0.4);
      color: #ffc107;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
      transition: 0.3s ease;
    }

    .gov-step-item:hover .gov-step-num{
      background: #ffc107;
      color: white;
    }

